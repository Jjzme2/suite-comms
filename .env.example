# Firebase — same project as ILYTAT PM
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Hub URL — used for SSO auth redirects and "Back to Hub" link
# Local: http://localhost:3000   Production: https://hub.ilytat.com
NUXT_PUBLIC_HUB_URL=http://localhost:3000

# Anthropic API key — for Claude cloud models (server-side only)
ANTHROPIC_API_KEY=

# Google Gemini API key — for Gemini cloud models (server-side only)
GEMINI_API_KEY=

# OpenRouter API key — unlocks all OpenRouter models (server-side only)
OPENROUTER_API_KEY=
